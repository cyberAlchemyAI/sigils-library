{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Architecture Inventory",
  "type": "object",
  "required": ["version", "project", "layers", "concepts", "relationships", "gaps"],
  "properties": {
    "version": { "type": "string" },
    "project": { "type": "string" },
    "generated_at": { "type": "string" },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "owns", "evidence"],
        "properties": {
          "name": { "type": "string" },
          "owns": { "type": "array", "items": { "type": "string" } },
          "must_not_depend_on": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "layer", "contract", "evidence"],
        "properties": {
          "name": { "type": "string" },
          "layer": { "type": "string" },
          "contract": { "type": "string" },
          "card": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "from", "to", "contract", "evidence"],
        "properties": {
          "name": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "contract": { "type": "string" },
          "card": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["summary", "severity"],
        "properties": {
          "summary": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "severe"] },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
